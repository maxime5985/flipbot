{
  "name": "flipbot",
  "version": "1.0.0",
  "description": "Bot de détection de bonnes affaires sur Vinted",
  "main": "dist/src/scheduler.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/scheduler.js",
    "dev": "ts-node src/scheduler.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "node-cron": "^3.0.3",
    "tough-cookie": "^4.1.4",
    "axios-cookiejar-support": "^4.0.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/tough-cookie": "^4.0.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}